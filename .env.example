# Runtime
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3000

# MySQL (the MYSQL_* values configure compose.yaml)
MYSQL_DATABASE=nayepankh
MYSQL_USER=nayepankh
MYSQL_PASSWORD=
MYSQL_ROOT_PASSWORD=
DATABASE_URL=mysql://nayepankh:change-me@127.0.0.1:3306/nayepankh

# Kimi OAuth application (server-only values)
APP_ID=
APP_SECRET=
KIMI_AUTH_URL=
KIMI_OPEN_URL=
OWNER_UNION_ID=

# Browser-visible OAuth configuration
VITE_APP_ID=
VITE_KIMI_AUTH_URL=

# Set only when frontend and backend are deployed separately.
# Leave empty for the same-origin local/Railway deployment.
VITE_API_URL=

# Optional. Without this key, the assistant uses its built-in fallback answers.
OPENROUTER_API_KEY=
